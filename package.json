{
  "name": "workloop",
  "version": "0.6.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Zero-dependency local mission control for any repo: scan it into task cards, run a headless Claude Code fix loop per card, and watch it all live on a galaxy map of your codebase.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.mjs",
    "scan": "node scanner.mjs",
    "loop": "node loop/cli.mjs",
    "check:syntax": "node -e \"for(const f of require('fs').readdirSync('.').concat(require('fs').readdirSync('loop').map(x=>'loop/'+x)).filter(x=>x.endsWith('.mjs'))){require('child_process').execSync('node --check '+f);console.log('ok '+f)}\""
  }
}
